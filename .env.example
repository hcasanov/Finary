# HubSpot Private App Token
HUBSPOT_ACCESS_TOKEN=pat-eu1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# HubSpot App Secret (used to validate webhook signatures)
HUBSPOT_WEBHOOK_SECRET=

# Google Gemini API key (used by Vercel AI SDK — @ai-sdk/google)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-key

# Inngest — NOT required for local dev
# In dev: run `npx inngest-cli@latest dev -u http://localhost:3000/inngest` (no keys needed)
# In prod: get these from https://app.inngest.com → your app → API Keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
